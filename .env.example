# =============================================================
# AirVault Concierge — Environment Variables Reference
# Copy this file to .env and fill in your real values.
# =============================================================

# ── PayloadCMS + .js monorepo (payload-app/) ─────────────────────────────

# PayloadCMS signing secret — auto-generated by Render; override for local dev
# Generate: openssl rand -hex 32
PAYLOAD_SECRET=replace-with-random-64-char-string

# PostgreSQL connection string (auto-linked by Render Blueprint)
# PayloadCMS uses DATABASE_URI; legacy backend uses DATABASE_URL
DATABASE_URI=postgresql://user:pass@host/dbname
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# Redis connection string (auto-linked by Render Blueprint)
REDIS_URL=redis://user:pass@host:6379

# Upstash Kafka bootstrap endpoint — leave blank to disable Kafka consumer
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_DELAY_TOPIC=flight-delays
KAFKA_CLAIM_TOPIC=claim-processed

# Stripe secret key (live or test)
STRIPE_SECRET_KEY=sk_live_...

# RapidAPI key for flight data
RAPIDAPI_KEY=your_rapidapi_key_here

# Server URL (set to your Render service URL in production)
_PUBLIC_SERVER_URL=https://airvault-app.onrender.com

# ── Legacy Python backend (backend/) — kept for reference ────────────────────

# JWT signing secret — auto-generated by Render; override for local dev
JWT_SECRET=replace-with-random-64-char-string

# ── Frontend (Vercel / payload-app in production) ────────────────────────────

# Public backend URL — used by .js rewrites and browser API calls
_PUBLIC_API_URL=https://airvault-app.onrender.com
