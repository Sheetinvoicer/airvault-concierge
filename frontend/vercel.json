{
  "framework": "js",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rootDirectory": "frontend",
  "env": {
    "_PUBLIC_API_URL": "@_public_api_url"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "$_PUBLIC_API_URL/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "$_PUBLIC_API_URL/ws/:path*"
    },
    {
      "source": "/graphql",
      "destination": "$_PUBLIC_API_URL/graphql"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
