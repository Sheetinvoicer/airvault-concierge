# ── PayloadCMS + Next.js ────────────────────────────────────────────────────

# PayloadCMS secret (generate with: openssl rand -hex 32)
PAYLOAD_SECRET=replace-with-random-64-char-string

# Postgres connection string (Render auto-links this)
DATABASE_URI=postgresql://airvault:airvaultpass@localhost:5432/airvault
# Alias used by legacy code — PayloadCMS reads DATABASE_URI
DATABASE_URL=postgresql://airvault:airvaultpass@localhost:5432/airvault

# Redis (Render managed Redis or Upstash)
REDIS_URL=redis://localhost:6379

# Kafka (optional — leave blank to disable delay-claim consumer)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_DELAY_TOPIC=flight-delays
KAFKA_CLAIM_TOPIC=claim-processed

# Stripe (for compensation payouts)
STRIPE_SECRET_KEY=sk_test_...

# RapidAPI (Skyscanner flight search)
RAPIDAPI_KEY=...

# Public URLs
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
