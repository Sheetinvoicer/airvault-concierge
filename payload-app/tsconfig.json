{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "es"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "es",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": ""
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@payload-config": [
        "./src/payload.config.ts"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "./types/**/*.ts",
    "./dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
